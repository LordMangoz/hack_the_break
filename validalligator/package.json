{
  "name": "validalligator",
  "displayName": "ValidAlligator",
  "description": "An Html, css, and javascript validator for beginner, or intermediate web developers. All in VS Code! ",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "my-activitybar",
          "title": "ValidAlligator",
          "icon": "media/aperture-svgrepo-com.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "myVew",
        "contents": "Welcome to ValidAlligator! This is a simple extension that will help you validate your HTML and give suggestions to help you along your way of learning web development."
      }
    ],
    "views": {
      "my-activitybar": [
        {
          "id": "myVew",
          "name": "ValidAlligator toolbar",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "validalligator.AItoggle",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "validalligator.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "validalligator.AItoggle",
        "title": "Toggle AI Suggestions"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "dotenv": "^17.3.1"
  }
}
