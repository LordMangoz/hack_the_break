{
  "name": "validalligator",
  "displayName": "ValidAlligator",
  "description": "An Html, css, and javascript validator for beginner, or intermediate web developers. All in VS Code! ",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.cjs",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "my-activitybar",
          "title": "ValidAlligator",
          "icon": "media/aperture-svgrepo-com.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "myVew",
        "contents": "Welcome to ValidAlligator! This is a simple extension that will help you validate your HTML and give suggestions to help you along your way of learning web development."
      }
    ],
    "views": {
      "my-activitybar": [
        {
          "id": "myVew",
          "name": "ValidAlligator toolbar",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "validalligator.AItoggle",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "validalligator.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "validalligator.highlightWarnings",
        "title": "Hightlight Warnings"
      },
      {
        "command": "validalligator.updateDirectory",
        "title": "Change note.md directory"
      },
      {
        "command": "validalligator.testNote",
        "title": "Take note"
      },
      {
        "command": "validalligator.headerSelector",
        "title": "Update number of hashtags headers for timestamps for note.md"
      },
      {
        "command": "validalligator.AItoggle",
        "title": "Toggle AI Suggestions"
      },
      {
        "command": "validalligator.suggestText",
        "title": "Suggestions"
      },
      {
        "command": "validalligator.debuggingText",
        "title": "Debug"
      },
      {
        "command": "validalligator.refactorText",
        "title": "Refactor"
      },
      {
        "command": "validalligator.updateFileName",
        "title": "Change File Name"
      },
      {
        "command": "validalligator.updateExtensionName",
        "title": "Change Extension Name"
      },
      {
        "command": "validalligator.setAPIKey",
        "title": "SET API KEY"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "dotenv": "^17.3.1",
    "marked": "^17.0.4"
  }
}
